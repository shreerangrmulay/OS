#include<iostream>

using namespace std;

class process
{

    public:

    int pid;
    int at;
    int bt;
    int st;
    int ct;
    int tat;
    int wt;
    int rt;

    void init(int pid,int at,int bt)
    {
        this->pid = pid;
        this->at = at;
        this->bt = bt;
    }
};

int main()
{

    int n = 0;
    cout << "Enter number of processes: ";
    cin >> n;

    process ps[n];
    int pid = 0;
    int at = 0;
    int bt = 0;


    for(int i = 0; i < n; i++)
    {
        cout<<endl<< "Enter process id for process " << i+1<< ": ";
        cin >> pid;
        cout<<endl<< "Enter arrival time for process:  " << i+1<<": ";
        cin >> at;
        cout<<endl<< "Enter burst time for process  " << i+1<<": ";
        cin >> bt;

        ps[i].init(pid,at,bt);
        
    }

    int atat = 0;
    int awt = 0;
    float throughput = n;

    ps[0].st = ps[0].at;
    ps[0].ct = ps[0].st + ps[0].bt;
    ps[0].tat = ps[0].ct - ps[0].at;
    ps[0].wt = ps[0].tat - ps[0].bt;
    ps[0].rt = ps[0].wt;

    atat += ps[0].tat;
    awt += ps[0].wt;

    for(int i = 1; i < n; i++)
    {
        if(ps[i-1].ct <= ps[i].at )
        {
            ps[i].st = ps[i].at;
        }
        else
        {
            ps[i].st = ps[i-1].ct;
        }

        ps[i].ct = ps[i].st + ps[i].bt;
        ps[i].tat = ps[i].ct - ps[i].at;
        ps[i].wt = ps[i].tat - ps[i].bt;
        ps[i].rt = ps[i].wt;

        atat += ps[i].tat;
        awt += ps[i].wt;

    }

    throughput = 1.0 * throughput/(ps[n-1].ct-ps[0].at);
    awt = awt/n;
    atat = atat/n;

    cout<< endl<<"Pid "<<"AT " << "BT " << "CT "<< "TAT " << "WT " <<"RT ";   
    for(int i = 0; i < n; i++)
    {
        cout<<endl<<ps[i].pid<<"   "<<ps[i].at<<"  "<<ps[i].bt<<"  "<<ps[i].ct<<"  "
        <<ps[i].tat<<"   "<<ps[i].wt<<"  "<<ps[i].rt;
    }

    cout<<endl<<endl<<"ATAT = "<<atat;
    cout<<endl<<"AWT = "<<awt; 
    cout<<endl<<"Throughput = "<<throughput; 

    return 0;
}

