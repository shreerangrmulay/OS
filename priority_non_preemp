#include <stdio.h>
#include <stdbool.h>
#include <limits.h>

struct Process
{
    int PID, AT, BT, CT, TAT, WT, PR;
    bool completed;
};

void PriorityNonPreemptive()
{
    int n;
    printf("Enter the number of Processes:-");
    scanf("%d", &n);

    struct Process P[n];
    float Avg_TAT = 0;
    float Avg_wt = 0;
    int ogBT[n];

    for (int i = 0; i < n; i++)
    {
        P[i].completed = false;
    }

    for (int i = 0; i < n; i++)
    {
        int Burst_time;
        printf("Process %d\n", i + 1);
        P[i].PID = i + 1;

        printf("Enter Arrival time of process(ms) %d :-", i + 1);
        scanf("%d", &P[i].AT);

        printf("Enter Burst Time(ms) of process %d :-", i + 1);
        scanf("%d", &Burst_time);
        P[i].BT = Burst_time;
        ogBT[i] = Burst_time;

        printf("Enter the priority of the process :- ");
        scanf("%d", &P[i].PR);
    }

    int current_time = 0;
    int completed_count = 0;

    while (completed_count < n)
    {
        int ind = -1;
        int highest_priority = INT_MAX;

        for (int i = 0; i < n; i++)
        {
            if (P[i].AT <= current_time && P[i].completed == false)
            {
                if (P[i].PR < highest_priority)
                {
                    highest_priority = P[i].PR;
                    ind = i;
                }
                else if (P[i].PR == highest_priority)
                {
                    if (P[i].AT < P[ind].AT)
                    {
                        ind = i;
                    }
                }
            }
        }

        if (ind == -1)
        {
            current_time++;
        }
        else
        {
            current_time += P[ind].BT;
            P[ind].CT = current_time;
            P[ind].TAT = P[ind].CT - P[ind].AT;
            P[ind].WT = P[ind].TAT - ogBT[ind];

            Avg_TAT += P[ind].TAT;
            Avg_wt += P[ind].WT;

            P[ind].completed = true;
            completed_count++;
        }
    }

    for(int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            if(P[i].CT > P[j].CT){
                struct Process temp;
                temp = P[i];
                P[i] = P[j];
                P[j] = temp;
            }
        }
    }
    printf("\nPID\tAT\tBT\tPR\tCT\tTAT\tWT\n");

    for (int i = 0; i < n; i++)
    {
        printf("%d\t%d\t%d\t%d\t%d\t%d\t%d\n",P[i].PID, P[i].AT, ogBT[i], P[i].PR,P[i].CT, P[i].TAT, P[i].WT);
    }

    printf("\nAverage Turnaround Time = %.2f\n", Avg_TAT / n);
    printf("Average Waiting Time = %.2f\n", Avg_wt / n);
}

int main()
{
    PriorityNonPreemptive();
    return 0;
}
