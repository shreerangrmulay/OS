#include <iostream>
#include <algorithm>
#include <cmath>
using namespace std;
int main(){
    int n;
    cout << "Enter number of tracks : ";
    cin >> n;
    int RQ[n];
    for(int i = 0; i < n; i++){
        cout << "Enter the element of RQ : " << i+1 << " ";
        cin >> RQ[i];
    }
    cout << "Enter the starting value : ";
    int initial;
    cin >> initial;
    int i, seektime, thm = 0;
    bool visited[n] = {false};

    cout << "The track movement is : ";
    cout << initial;

    for(int i = 0; i < n; i++){

        int min = 9999;
        int index = -1;

        for(int j = 0; j < n; j++){

            if(!visited[j] && abs(initial - RQ[j]) < min){
                min = abs(initial - RQ[j]);
                index = j;
            }
        }

        visited[index] = true;

        thm += abs(initial - RQ[index]);

        cout << " -> " << RQ[index];

        initial = RQ[index];
    }
    
    
    seektime = thm;
    
    cout << endl <<"The total head movement : " << thm << endl;
    cout << "The seek time is : " << seektime;
    return 0;
}
