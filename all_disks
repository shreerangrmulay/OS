#include <stdio.h>
#include <stdlib.h>

int abs_val(int x) {
    return x > 0 ? x : -x;
}

void fcfs(int req[], int n, int head) {
    int seek = 0;
    printf("FCFS Movement: %d", head);
    for (int i = 0; i < n; i++) {
        seek += abs_val(req[i] - head);
        head = req[i];
        printf(" -> %d", head);
    }
    printf("\nFCFS Seek Time: %d\n\n", seek);
}

void sstf(int req[], int n, int head) {
    int visited[100] = {0};
    int seek = 0;

    printf("SSTF Movement: %d", head);

    for (int i = 0; i < n; i++) {
        int min = 1e9, index = -1;
        for (int j = 0; j < n; j++) {
            if (!visited[j] && abs_val(req[j] - head) < min) {
                min = abs_val(req[j] - head);
                index = j;
            }
        }
        visited[index] = 1;
        seek += abs_val(req[index] - head);
        head = req[index];
        printf(" -> %d", head);
    }

    printf("\nSSTF Seek Time: %d\n\n", seek);
}

void scan(int req[], int n, int head, int disk_size, int direction) {
    int seek = 0;
    int left[100], right[100];
    int l = 0, r = 0;

    printf("SCAN Movement: %d", head);

    for (int i = 0; i < n; i++) {
        if (req[i] < head)
            left[l++] = req[i];
        else
            right[r++] = req[i];
    }

    if (direction == 0)
        left[l++] = 0;
    else
        right[r++] = disk_size - 1;

    for (int i = 0; i < l - 1; i++)
        for (int j = 0; j < l - i - 1; j++)
            if (left[j] > left[j + 1]) {
                int t = left[j];
                left[j] = left[j + 1];
                left[j + 1] = t;
            }

    for (int i = 0; i < r - 1; i++)
        for (int j = 0; j < r - i - 1; j++)
            if (right[j] > right[j + 1]) {
                int t = right[j];
                right[j] = right[j + 1];
                right[j + 1] = t;
            }

    if (direction == 1) {
        for (int i = 0; i < r; i++) {
            seek += abs_val(right[i] - head);
            head = right[i];
            printf(" -> %d", head);
        }
        for (int i = l - 1; i >= 0; i--) {
            seek += abs_val(left[i] - head);
            head = left[i];
            printf(" -> %d", head);
        }
    } else {
        for (int i = l - 1; i >= 0; i--) {
            seek += abs_val(left[i] - head);
            head = left[i];
            printf(" -> %d", head);
        }
        for (int i = 0; i < r; i++) {
            seek += abs_val(right[i] - head);
            head = right[i];
            printf(" -> %d", head);
        }
    }

    printf("\nSCAN Seek Time: %d\n\n", seek);
}

void cscan(int req[], int n, int head, int disk_size) {
    int seek = 0;
    int left[100], right[100];
    int l = 0, r = 0;

    printf("C-SCAN Movement: %d", head);

    for (int i = 0; i < n; i++) {
        if (req[i] < head)
            left[l++] = req[i];
        else
            right[r++] = req[i];
    }

    left[l++] = 0;
    right[r++] = disk_size - 1;

    for (int i = 0; i < l - 1; i++)
        for (int j = 0; j < l - i - 1; j++)
            if (left[j] > left[j + 1]) {
                int t = left[j];
                left[j] = left[j + 1];
                left[j + 1] = t;
            }

    for (int i = 0; i < r - 1; i++)
        for (int j = 0; j < r - i - 1; j++)
            if (right[j] > right[j + 1]) {
                int t = right[j];
                right[j] = right[j + 1];
                right[j + 1] = t;
            }

    for (int i = 0; i < r; i++) {
        seek += abs_val(right[i] - head);
        head = right[i];
        printf(" -> %d", head);
    }

    head = 0;
    seek += (disk_size - 1);
    printf(" -> %d", head);

    for (int i = 0; i < l; i++) {
        seek += abs_val(left[i] - head);
        head = left[i];
        printf(" -> %d", head);
    }

    printf("\nC-SCAN Seek Time: %d\n\n", seek);
}

int main() {
    int n, head, disk_size;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    int *req = (int *)malloc(n * sizeof(int));

    printf("Enter request sequence: ");
    for (int i = 0; i < n; i++)
        scanf("%d", &req[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    printf("Enter disk size: ");
    scanf("%d", &disk_size);

    printf("\n");

    fcfs(req, n, head);
    sstf(req, n, head);
    scan(req, n, head, disk_size, 1);
    cscan(req, n, head, disk_size);

    free(req);
    return 0;
}
