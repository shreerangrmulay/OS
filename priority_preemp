#include <stdio.h>
#include <stdbool.h>
#include <limits.h>
#include <stdlib.h>
struct Process
{
    int PID, AT, BT, CT, TAT, WT, PR;
    bool completed;
};
void PriorityPreemptive()
{
    int n;
    printf("Enter the number of Processes:-");
    scanf("%d", &n);

    struct Process *P;

    float Avg_TAT = 0;
    float Avg_WT = 0;
    int *ogBT;

    ogBT = malloc(n* sizeof(int));

    P = (struct Process*) malloc(n*sizeof(struct Process));
    if(P == NULL){
        printf("Memory allocation failed!");
    }
    for (int i = 0; i < n; i++)
    {
        P[i].completed = false;
    }
    for (int i = 0; i < n; i++)
    {
        int Burst_time;
        printf("Process %d\n", i + 1);
        P[i].PID = i + 1;

        printf("Enter Arrival time of process(ms) %d :-", i + 1);
        scanf("%d", &P[i].AT);

        printf("Enter Burst Time(ms) of process %d :-", i + 1);
        scanf("%d", &Burst_time);
        P[i].BT = Burst_time;
        ogBT[i] = Burst_time;

        printf("Enter the priority of the process :- ");
        scanf("%d", &P[i].PR);
    }
    int count = 0;
    int current_Time = 0;

    while (count < n)
    {
        int ind = -1;
        int priority = INT_MAX;
        for (int i = 0; i < n; i++)
        {
            if (P[i].AT <= current_Time && P[i].completed == false)
            {
                if (P[i].PR < priority)
                {
                    ind = i;
                    priority = P[i].PR;
                }
                else if (P[i].PR == priority)
                {
                    if (P[i].AT < P[ind].AT)
                    {
                        ind = i;
                    }
                }
            }
        }
        if (ind == -1)
        {
            current_Time++;
            continue;
        }
        ogBT[ind]--;
        if (ogBT[ind] == 0)
        {
            P[ind].completed = true;
            count++;
        }
        if (P[ind].completed == true)
        {
            P[ind].CT = current_Time + 1;
            P[ind].TAT = P[ind].CT - P[ind].AT;
            P[ind].WT = P[ind].TAT - P[ind].BT;
        }
        current_Time++;
    }

    for (int i = 0; i < n - 1; i++)
    {
        for (int j = 0; j < n - i - 1; j++)
        {
            if (P[j].CT > P[j + 1].CT)
            {
                struct Process temp = P[j];
                P[j] = P[j + 1];
                P[j + 1] = temp;
            }
        }
    }
    printf("\nPID\tAT\tBT\tPR\tCT\tTAT\tWT\n");

    for (int i = 0; i < n; i++)
    {
        printf("%d\t%d\t%d\t%d\t%d\t%d\t%d\n", P[i].PID, P[i].AT, P[i].BT, P[i].PR, P[i].CT, P[i].TAT, P[i].WT);
    }

    for(int i=0 ; i<n ; i++){
        Avg_TAT += P[i].TAT;
        Avg_WT += P[i].WT;
    }
    printf("\nAverage Turnaround Time = %.2f\n", Avg_TAT / n);
    printf("Average Waiting Time = %.2f\n", Avg_WT / n);

    free(P);
}
int main()
{
    PriorityPreemptive();
}
