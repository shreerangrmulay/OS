#include<stdio.h>
#include <stdbool.h>
#include <limits.h>

struct Process
{
    int PID,AT,BT,CT,TAT,WT;
    bool completed ;
};
void ShortestJobFirst(){

    
    int n;
    printf("Enter the number of Processes:-");
    scanf("%d",&n);
    struct Process P[n];
    float Avg_TAT=0;
    float Avg_wt=0;
    int ogBT[n];


    for(int i=0;i<n;i++){
        P[i].completed=false;
    }

    for(int i=0;i<n;i++){
        int Arrival_Time,Burst_time;
        printf("Process %d",i+1);
        P[i].PID=i+1;
        printf("\n");

        printf("Enter Arrival time of process(ms) %d :-" , i+1);
        scanf("%d",&Arrival_Time);
        P[i].AT=Arrival_Time;

        printf("Enter Burst Time(ms) of process %d :-" , i+1);
        scanf("%d",&Burst_time);
        P[i].BT=Burst_time;
        ogBT[i]=Burst_time;
    }
    int current_time=0;
    int count=0;
    while(count<n){
        int ind=-1;
        int minBT=INT_MAX;
        for(int i=0;i<n;i++){
            if(P[i].AT<=current_time && P[i].completed == false){
                if( ogBT[i] < minBT ){
                    minBT=ogBT[i];
                    ind =i;
                }
                else if(ogBT[i] == P[ind].BT){
                    if(ind == -1 || i<ind){
                        ind=i;
                    }
                }
            }
            else continue;
        }

        if(ind == -1){
            current_time++;
        }
        else{
            ogBT[ind]--;
            current_time++;
        }

        if(ind !=-1 && ogBT[ind] == 0){
            P[ind].completed=true;
            P[ind].CT=current_time;
            P[ind].TAT=P[ind].CT-P[ind].AT;
            P[ind].WT=P[ind].TAT-P[ind].BT;
            count++;
        }
    }

    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
            if(P[i].CT > P[j].CT){
                struct Process temp;
                temp=P[i];
                P[i]=P[j];
                P[j]=temp;
                
            }
        }
    }

    printf("PID\tAT\tBT\tCT\tTAT\tWT\n");
    for(int i=0;i<n;i++){
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",P[i].PID,P[i].AT,P[i].BT,P[i].CT,P[i].TAT,P[i].WT);
    }
    printf("\nAverage TAT is:- ");
    for(int i=0;i<n;i++){
        Avg_TAT+=P[i].TAT;
    }
    printf("%0.2f",Avg_TAT/n);
    printf("\nAverage WT is :- ");
    for(int i=0;i<n;i++){
        Avg_wt+=P[i].WT;
    }
    printf("%0.2f",Avg_wt/n);
}
int main(){
    ShortestJobFirst();
}
